{
    "name": "fortune-market",
    "version": "0.0.1-alpha",
    "description": "Prediction market design on Base using Uniswap v4",
    "private": true,
    "license": "MIT",
    "scripts": {
        "compile": "hardhat compile",
        "test": "npm run test:fast && npm run test:fork",
        "test:fast": "hardhat test test/payoutScenarios.ts",
        "test:fork": "cross-env ENABLE_FORKING=1 hardhat test test/forkLifecycle.ts",
        "generate:scenario-svg": "ts-node tools/generate-payout-scenarios-svg.ts",
        "deploy": "hardhat run scripts/deploy.ts --network base",
        "create:market": "hardhat run scripts/create-market.ts --network base",
        "smoke:market": "hardhat run scripts/smoke-market.ts --network base",
        "quote:slippage": "cross-env ENABLE_FORKING=1 hardhat run scripts/quote-slippage.ts"
    },
    "engines": {
        "node": ">=20"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@nomicfoundation/hardhat-ethers": "^3.0.0",
        "@typechain/ethers-v6": "^0.5.0",
        "@typechain/hardhat": "^9.0.0",
        "@types/node": "^20.11.0",
        "cross-env": "^7.0.3",
        "hardhat": "^2.22.0",
        "ts-node": "^10.9.2",
        "typechain": "^8.3.0",
        "typescript": "^5.3.0"
    },
    "dependencies": {
        "@openzeppelin/contracts": "^5.0.0",
        "@uniswap/v4-core": "github:Uniswap/v4-core#v4.0.0",
        "@uniswap/v4-periphery": "github:Uniswap/v4-periphery#v4.0.0",
        "dotenv": "^16.4.0",
        "ethers": "^6.11.0"
    }
}
